# Cloudflare Pages frontend environment variables

VITE_APP_BACKEND_PROVIDER=local
# Set this to the hosted ops bridge to unlock live Admin Operations
# refresh, runner audit, scheduler visibility, and manual pipeline control.
# Leave blank only if the frontend must stay read-only against static snapshots.
VITE_API_ORIGIN=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
