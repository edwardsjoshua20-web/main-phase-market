{
  "jobs": [
    {
      "id": "fab-backfill",
      "label": "Backfill FAB cards",
      "command": "npm",
      "args": ["run", "fab:backfill:cards"],
      "enabled": true
    },
    {
      "id": "lorcana-backfill",
      "label": "Backfill Lorcana cards",
      "command": "npm",
      "args": ["run", "lorcana:backfill:cards"],
      "enabled": true
    },
    {
      "id": "pokemon-backfill",
      "label": "Backfill Pokemon cards",
      "command": "npm",
      "args": ["run", "pokemon:backfill:cards"],
      "requires": [
        { "type": "source-exists", "game": "pokemon", "key": "catalogSource", "label": "Pokemon source export" }
      ],
      "enabled": true
    },
    {
      "id": "onepiece-backfill",
      "label": "Backfill One Piece cards",
      "command": "npm",
      "args": ["run", "onepiece:backfill:cards"],
      "enabled": true
    },
    {
      "id": "yugioh-backfill",
      "label": "Backfill Yu-Gi-Oh cards",
      "command": "npm",
      "args": ["run", "yugioh:backfill:cards"],
      "enabled": true
    },
    {
      "id": "starwars-backfill",
      "label": "Backfill Star Wars cards",
      "command": "npm",
      "args": ["run", "starwars:backfill:cards"],
      "enabled": true
    }
  ]
}
