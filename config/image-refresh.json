{
  "jobs": [
    {
      "id": "mtg-images",
      "label": "Mirror MTG images",
      "command": "npm",
      "args": ["run", "mtg:mirror:images", "--", "small,normal,art_crop"],
      "requires": [
        { "type": "source-exists", "game": "magic", "key": "catalogSource", "label": "MTG source export" }
      ],
      "enabled": true
    },
    {
      "id": "fab-images",
      "label": "Mirror FAB images",
      "command": "npm",
      "args": ["run", "fab:mirror:images"],
      "requires": [
        { "type": "file-exists", "path": "public/data/fab/cards.json", "label": "FAB cards catalog" }
      ],
      "enabled": true
    },
    {
      "id": "lorcana-images",
      "label": "Mirror Lorcana images",
      "command": "npm",
      "args": ["run", "lorcana:mirror:images"],
      "requires": [
        { "type": "file-exists", "path": "public/data/lorcana/cards.json", "label": "Lorcana cards catalog" }
      ],
      "enabled": true
    },
    {
      "id": "pokemon-images",
      "label": "Mirror Pokemon images",
      "command": "npm",
      "args": ["run", "pokemon:mirror:images"],
      "requires": [
        { "type": "source-exists", "game": "pokemon", "key": "catalogSource", "label": "Pokemon source export" }
      ],
      "enabled": true
    },
    {
      "id": "onepiece-images",
      "label": "Mirror One Piece images",
      "command": "npm",
      "args": ["run", "onepiece:mirror:images"],
      "requires": [
        { "type": "file-exists", "path": "public/data/onepiece/cards.json", "label": "One Piece cards catalog" }
      ],
      "enabled": true
    },
    {
      "id": "yugioh-images",
      "label": "Mirror Yu-Gi-Oh images",
      "command": "npm",
      "args": ["run", "yugioh:mirror:images"],
      "requires": [
        { "type": "file-exists", "path": "public/data/yugioh/cards.json", "label": "Yu-Gi-Oh cards catalog" }
      ],
      "enabled": true
    },
    {
      "id": "starwars-images",
      "label": "Mirror Star Wars images",
      "command": "npm",
      "args": ["run", "starwars:mirror:images"],
      "requires": [
        { "type": "file-exists", "path": "public/data/starwars/cards.json", "label": "Star Wars cards catalog" }
      ],
      "enabled": true
    }
  ]
}
